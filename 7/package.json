{
  "name": "fe-07-kanban-board",
  "private": true,
  "version": "0.7.0",
  "description": "Kanban Board — drag-and-drop board scaffold with MSW mock server and optimistic move TODOs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:slow": "cross-env VITE_KANBAN_SCENARIO=slow vite",
    "dev:empty": "cross-env VITE_KANBAN_SCENARIO=empty vite",
    "dev:move-failure": "cross-env VITE_KANBAN_SCENARIO=move-failure vite",
    "dev:stale-version": "cross-env VITE_KANBAN_SCENARIO=stale-version vite",
    "dev:large-board": "cross-env VITE_KANBAN_SCENARIO=large-board vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.59.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "@vitejs/plugin-react": "^4.3.3",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.13",
    "jsdom": "^25.0.1",
    "msw": "^2.4.11",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.3"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
